# ==========================================
# SmartRetail 360 – Environment Settings Template
# Copy this file to '.env' and fill in your custom credentials
# ==========================================

# 1. MongoDB Database Settings
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/smartretail360

# 2. Redis Caching Settings
REDIS_HOST=localhost
REDIS_PORT=6379

# 3. Store Configuration
APP_STORE_NAME=SmartRetail 360 flagship
APP_STORE_STATE=Karnataka
APP_STORE_GSTIN=29AAAAA1111A1Z1

# 4. Security & JWT Settings
APP_JWT_SECRET=YOUR_SECURE_JWT_SIGNING_SECRET_KEY
APP_JWT_EXPIRATION_MS=86400000

# 5. Email Server Settings (SMTP)
SPRING_MAIL_HOST=smtp.mailtrap.io
SPRING_MAIL_PORT=2525
SPRING_MAIL_USERNAME=your-smtp-username
SPRING_MAIL_PASSWORD=your-smtp-password

# 6. React Frontend Settings
VITE_API_BASE_URL=http://localhost:8080/api
